---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Jestus A — Angular Developer | Full Stack Engineer">
  <!-- ===== NAVBAR ===== -->
  <nav class="navbar" id="navbar">
    <a href="#hero" class="nav-logo">Jestus<span>.A</span></a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#achievements">Impact</a></li>
      <li><a href="#education">Education</a></li>
      <li><a href="#resume">Resume</a></li>
      <li><a href="#contact" class="nav-cta">Contact</a></li>
    </ul>
    <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile Nav Overlay -->
  <div class="nav-mobile" id="mobileNav">
    <a href="#about" class="mobile-link">About</a>
    <a href="#skills" class="mobile-link">Skills</a>
    <a href="#experience" class="mobile-link">Experience</a>
    <a href="#achievements" class="mobile-link">Impact</a>
    <a href="#education" class="mobile-link">Education</a>
    <a href="#resume" class="mobile-link">Resume</a>
    <a href="#contact" class="mobile-link">Contact</a>
  </div>

  <!-- ===== HERO ===== -->
  <section id="hero">
    <div class="hero-bg">
      <div class="hero-blob-1"></div>
      <div class="hero-blob-2"></div>
    </div>
    <div class="hero-grid"></div>
    <div class="particles-container"></div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-badge">
          <span>Available for new opportunities</span>
        </div>
        <h1 class="hero-name">
          <span class="line1">Hi, I'm</span>
          <span class="line2">Jestus A</span>
        </h1>
        <p class="hero-role">
          &lt; <span class="typed-text">Angular Developer</span> /&gt;
        </p>
        <p class="hero-desc">
          Angular Developer with <strong>3+ years</strong> of experience crafting
          scalable, high-performance web applications. Specialized in Angular, TypeScript,
          JavaScript, RxJS, NgRx, NodeJS, PostgreSQL, ExpressJS, GraphQL and Astro.
        </p>
        <div class="hero-actions">
          <a href="#experience" class="btn-primary">
            <span>View My Work</span>
            <span>→</span>
          </a>
          <a href="#contact" class="btn-secondary">
            <span>Get in Touch</span>
          </a>
          <a
            href="/Jestus_A_Resume.pdf"
            download="Jestus_A_Resume.pdf"
            class="btn-secondary"
          >
            <span>Download CV</span>
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-num">3+</div>
            <div class="stat-label">Years of Experience</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">Scalable</div>
            <div class="stat-label">Architecture Design</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">Seamless</div>
            <div class="stat-label">API Integrations</div>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-image-wrapper">
          <div class="hero-image-ring"></div>
          <div class="hero-image-ring-2"></div>
          <div class="hero-orbit hero-orbit"></div>
          <div class="hero-orbit hero-orbit-2"></div>
          <div class="hero-orbit hero-orbit-3"></div>
          <div class="hero-image-inner">
            <img src="/jestus.jpg" alt="Jestus A - Angular Developer" />
          </div>
        </div>
        <div class="tech-badge tech-badge-1">
          <div class="dot"></div> Angular 18
        </div>
        <div class="tech-badge tech-badge-2">
          <div class="dot"></div> NgRx
        </div>
        <div class="tech-badge tech-badge-3">
          <div class="dot"></div> TypeScript
        </div>
        <div class="tech-badge tech-badge-4">
          <div class="dot"></div> Node.js
        </div>
      </div>
    </div>

    <!-- scroll indicator -->
    <div
      style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:0.5rem;opacity:0.45;animation:float-y 2.5s ease-in-out infinite;"
    >
      <span
        style="font-family:var(--font-mono);font-size:0.62rem;letter-spacing:0.12em;color:var(--text-muted);"
        >SCROLL</span
      >
      <div
        style="width:1px;height:38px;background:linear-gradient(to bottom,var(--accent-coral),transparent);"
      >
      </div>
    </div>
  </section>

  <!-- ===== ABOUT =====
       Pattern: label drops from top · title slides from LEFT · text slides from LEFT
                achievement cards slide from RIGHT with stagger
  -->
  <section id="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-left">
          <div class="section-label reveal-down">Professional Summary</div>
          <h2 class="section-title reveal-left delay-100">
            Building the Web,<br />
            <span class="gradient-text">One Component</span> at a Time
          </h2>
          <div class="reveal-left delay-200">
            <p
              class="about-text"
              style="color:var(--text-secondary);font-size:1.05rem;line-height:1.9;margin-bottom:1.5rem;"
            >
              Angular Developer with <span
                style="color:var(--accent-coral);font-weight:600;"
                >3+ years</span
              > of experience building scalable, high-performance web applications
              using Angular 18, TypeScript, RxJS, and NgRx. Strong expertise in UI
              development, component architecture, lazy loading, standalone components,
              and state management.
            </p>
            <p
              class="about-text"
              style="color:var(--text-secondary);font-size:1.05rem;line-height:1.9;margin-bottom:1.5rem;"
            >
              Also experienced in backend development using <span
                style="color:var(--accent-indigo);font-weight:600;"
                >Node.js, Express, and PostgreSQL</span
              >, building scalable REST and GraphQL APIs with improved
              performance and reliability.
            </p>
            <p
              class="about-text"
              style="color:var(--text-secondary);font-size:1.05rem;line-height:1.9;"
            >
              Skilled in developing a <span
                style="color:var(--accent-sage);font-weight:600;"
                >multi-tenant SaaS eCommerce platform (Zenbasket)</span
              > and delivering end-to-end full-stack solutions in Agile environments.
            </p>
            <div class="about-highlight" style="margin-top:2rem;">
              <p
                style="color:var(--text-secondary);font-size:0.95rem;line-height:1.7;"
              >
                📍 <strong>Tamil Nadu, India</strong> &nbsp;|&nbsp; 💼 Currently at
                <strong>Centizen Inc.</strong> &nbsp;|&nbsp; 🎓 <strong
                  >B.E. Computer Science, CGPA: 8.5
                </strong>(with Distinction)
              </p>
            </div>
          </div>
        </div>

        <!-- Cards slide in from RIGHT -->
        <div class="about-achievements">
          <div class="achievement-card reveal-right delay-100">
            <div class="achievement-icon">🔥</div>
            <div class="achievement-num">3rd-Party Shipment Integration</div>
            <div class="achievement-desc">
              Seamlessly integrated multiple third-party shipping providers into
              Zenbasket, enabling automated order fulfillment, real-time
              tracking, and dynamic shipping rate calculation. Improved
              operational efficiency and reduced manual intervention in
              logistics workflows.
            </div>
          </div>
          <div class="achievement-card reveal-right delay-200">
            <div class="achievement-icon">⚡</div>
            <div class="achievement-num">WhatsApp Marketing Integration</div>
            <div class="achievement-desc">
              Built WhatsApp marketing automation features to enable store
              owners to send personalized campaigns, order updates, and
              promotional messages. Enhanced customer engagement and
              significantly improved conversion rates through real-time
              communication.
            </div>
          </div>
          <div class="achievement-card reveal-right delay-300">
            <div class="achievement-icon">🏢</div>
            <div class="achievement-num">Multi-Tenant Architecture</div>
            <div class="achievement-desc">
              Designed and developed a scalable multi-tenant SaaS architecture
              supporting multiple independent storefronts. Enabled efficient
              resource sharing, tenant isolation, and rapid onboarding of new
              businesses on a single platform.
            </div>
          </div>
          <div class="achievement-card reveal-right delay-400">
            <div class="achievement-icon">🔔</div>
            <div class="achievement-num">Live Notifications</div>
            <div class="achievement-desc">
              Implemented a real-time notification system for order updates,
              user activities, and sales events using reactive programming.
              Improved user engagement by delivering instant updates such as
              order status, cart activity, and live sales alerts.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SKILLS =====
       Pattern: label from top · title fades up (default) · cards ROTATE in with stagger
  -->
  <section id="skills">
    <div class="container">
      <div class="section-label reveal-down">Technical Arsenal</div>
      <h2 class="section-title reveal delay-100">
        Skills &amp; <span class="gradient-text">Technologies</span>
      </h2>
      <p
        class="reveal delay-200"
        style="color:var(--text-secondary);max-width:550px;line-height:1.8;margin-bottom:3rem;"
      >
        A curated set of technologies I use to build fast, scalable, and
        maintainable applications — from pixel-perfect UIs to robust backend
        systems.
      </p>

      <div class="skills-container">
        <div class="skill-category reveal-rotate delay-100">
          <div class="skill-category-title">⚡ Frontend</div>
          <div class="skill-tags">
            <span class="skill-tag cyan">Angular 18</span>
            <span class="skill-tag cyan">TypeScript</span>
            <span class="skill-tag cyan">RxJS</span>
            <span class="skill-tag cyan">NgRx</span>
            <span class="skill-tag cyan">Astro</span>
            <span class="skill-tag cyan">Angular Material</span>
            <span class="skill-tag cyan">Angular Signals</span>
            <span class="skill-tag cyan">Standalone Components</span>
            <span class="skill-tag cyan">Lazy Loading</span>
            <span class="skill-tag cyan">OnPush Strategy</span>
          </div>
        </div>

        <div class="skill-category reveal-rotate delay-200">
          <div class="skill-category-title">🛠️ Backend</div>
          <div class="skill-tags">
            <span class="skill-tag purple">Node.js</span>
            <span class="skill-tag purple">Express.js</span>
            <span class="skill-tag purple">REST API</span>
            <span class="skill-tag purple">GraphQL</span>
            <span class="skill-tag purple">Apollo Client</span>
            <span class="skill-tag purple">JSON-LD</span>
          </div>
        </div>

        <div class="skill-category reveal-rotate delay-300">
          <div class="skill-category-title">🗄️ Databases</div>
          <div class="skill-tags">
            <span class="skill-tag pink">PostgreSQL</span>
            <span class="skill-tag pink">MySQL</span>
            <span class="skill-tag pink">SQL</span>
          </div>
        </div>

        <div class="skill-category reveal-rotate delay-400">
          <div class="skill-category-title">🧰 Tools &amp; Core</div>
          <div class="skill-tags">
            <span class="skill-tag blue">Git</span>
            <span class="skill-tag blue">GitLab</span>
            <span class="skill-tag blue">Postman</span>
            <span class="skill-tag blue">Jest</span>
            <span class="skill-tag blue">Nx Monorepo</span>
            <span class="skill-tag blue">Agile / Scrum</span>
            <span class="skill-tag blue">Component Architecture</span>
            <span class="skill-tag blue">State Management</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EXPERIENCE =====
       Pattern: label from RIGHT · title from RIGHT · timeline items from LEFT
  -->
  <section id="experience">
    <div class="container">
      <div class="section-label reveal-right">Work History</div>
      <h2 class="section-title reveal-right delay-100">
        Professional <span class="gradient-text">Experience</span>
      </h2>

      <div class="timeline">
        <div class="timeline-item reveal-left">
          <div class="timeline-dot active"></div>
          <div class="exp-header">
            <div class="exp-role">Software Engineer — Angular Developer</div>
            <div class="exp-date">Feb 2023 – Present</div>
          </div>
          <div class="exp-company">Centizen Inc.</div>
          <div class="exp-location">📍 Tirunelveli, Tamil Nadu</div>
          <div class="exp-project-title">
            ▶ Zenbasket — Multi-Tenant SaaS eCommerce Platform
          </div>
          <ul class="exp-bullets">
            <li>
              Built and scaled a multi-tenant SaaS eCommerce platform using <strong
                >Angular 18</strong
              >, Nx monorepo, Standalone Components, and lazy loading, reducing
              bundle size by <span style="color:var(--accent-coral);">25%</span> and
              improving overall application performance
            </li>
            <li>
              Developed advanced add-on features including customer data
              import/export and multiple authentication methods (classic login
              and passwordless login), enhancing admin efficiency and user
              experience
            </li>
            <li>
              Integrated third-party shipping providers, enabling seamless order
              fulfillment and improving operational efficiency
            </li>
            <li>
              Integrated <strong>WhatsApp marketing automation</strong> for product
              promotions and offers, increasing customer engagement and sales conversions
            </li>
            <li>
              Designed and implemented <strong>multi-language support</strong> across
              admin and storefront applications using reusable component architecture,
              enabling expansion into diverse regional markets
            </li>
            <li>
              Built real-time user engagement features including visitor count,
              sales notifications, cart activity, and wishlist tracking,
              improving user interaction and conversion rates
            </li>
            <li>
              Managed complex application state using <strong
                >RxJS and NgRx</strong
              >, improving state predictability and reducing UI-related issues
              across modules
            </li>
            <li>
              Integrated REST and GraphQL APIs using <strong
                >RxJS and Apollo Client</strong
              > for efficient reactive data handling
            </li>
            <li>
              Developed and optimized backend services using <strong
                >Node.js, Express, and PostgreSQL</strong
              >, building scalable REST APIs and improving response time by <span
                style="color:var(--accent-coral);">30%</span
              > through query optimization and indexing
            </li>
            <li>
              Designed and maintained <strong
                >PostgreSQL database schemas</strong
              >, ensuring efficient data handling and scalability
            </li>
            <li>
              Maintained high code quality through unit testing using <strong
                >Jest</strong
              >
            </li>
            <li>
              Collaborated in an Agile environment, participating in sprint
              planning, code reviews, and production releases — progressing from
              intern to full-time Angular developer
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== KEY ACHIEVEMENTS =====
       Pattern: label from LEFT · title from LEFT · cards BLUR in with stagger
  -->
  <section id="achievements">
    <div class="container">
      <div class="section-label reveal-left">Measurable Impact</div>
      <h2 class="section-title reveal-left delay-100">
        Key <span class="gradient-text">Achievements</span>
      </h2>

      <div class="achievements-grid">
        <div class="achievement-item reveal-blur delay-100">
          <div class="achievement-number">25%</div>
          <div class="achievement-text">
            Reduced Angular application bundle size in the <strong
              >Zenbasket platform</strong
            > using lazy loading, standalone components, and module refactoring
          </div>
        </div>
        <div class="achievement-item reveal-blur delay-200">
          <div class="achievement-number">SaaS</div>
          <div class="achievement-text">
            Built and scaled a <strong
              >multi-tenant SaaS eCommerce platform (Zenbasket)</strong
            > supporting multiple storefronts using Angular 18
          </div>
        </div>
        <div class="achievement-item reveal-blur delay-300">
          <div class="achievement-number">30%</div>
          <div class="achievement-text">
            Improved API response time by developing and optimizing backend
            services using <strong>Node.js and PostgreSQL</strong> with efficient
            query optimization and indexing
          </div>
        </div>
        <div class="achievement-item reveal-blur delay-400">
          <div class="achievement-number">RxJS</div>
          <div class="achievement-text">
            Implemented scalable state management using <strong
              >RxJS and NgRx</strong
            > across multiple modules, improving application stability and reducing
            UI-related issues
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EDUCATION =====
       Pattern: label drops from top · title scales up · cards SCALE in
  -->
  <section id="education">
    <div class="container">
      <div class="section-label reveal-down">Academic Background</div>
      <h2 class="section-title reveal-scale delay-100">
        <span class="gradient-text">Education</span>
      </h2>

      <div class="education-grid">
        <div class="edu-card reveal-scale delay-200">
          <div class="edu-level">🎓 Bachelor of Engineering</div>
          <div class="edu-degree">Computer Science and Engineering</div>
          <div class="edu-school">
            Anna University Regional Campus, Tirunelveli, Tamil Nadu
          </div>
          <div class="edu-meta">
            <div class="edu-meta-item">
              📅 <span>2019 – 2023</span>
            </div>
            <div class="edu-meta-item">
              <span class="badge">CGPA: 8.5 / 10</span>
            </div>
            <div class="edu-meta-item">
              <span class="badge">Distinction</span>
            </div>
          </div>
        </div>

        <div class="edu-card reveal-scale delay-300">
          <div class="edu-level">📚 Higher Secondary Education</div>
          <div class="edu-degree">Higher Secondary Certificate (HSC)</div>
          <div class="edu-school">
            Rose Mary Matric Hr Sec School, Tirunelveli, Tamil Nadu
          </div>
          <div class="edu-meta">
            <div class="edu-meta-item">
              📅 <span>2019</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== RESUME ===== -->
  <section id="resume">
    <div class="container">
      <div class="section-label reveal-down">Career Document</div>
      <h2 class="section-title reveal-scale delay-100">
        My <span class="gradient-text">Resume</span>
      </h2>

      <div class="resume-wrapper reveal-scale delay-200">
        <div class="resume-card">
          <div class="resume-icon">📄</div>
          <div class="resume-info">
            <h3>Full Professional Resume</h3>
            <p>
              Looking for a more detailed overview of my career, projects, and
              technical certifications? Download my complete CV to see how I can
              bring value to your team.
            </p>
            <div class="resume-actions">
              <a
                href="/Jestus_A_Resume.pdf"
                download="Jestus_A_Resume.pdf"
                class="btn-primary"
              >
                <span>Download PDF</span>
                <span>↓</span>
              </a>
              <a
                href="/Jestus_A_Resume.pdf"
                target="_blank"
                class="btn-secondary"
              >
                <span>Preview Online</span>
              </a>
            </div>
          </div>
          <div class="resume-tags">
            <span class="skill-tag cyan">Angular 18</span>
            <span class="skill-tag purple">TypeScript</span>
            <span class="skill-tag pink">Node.js</span>
            <span class="skill-tag blue">Full Stack</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CONTACT =====
       Pattern: label from RIGHT · title from RIGHT · contact items from LEFT · CTA from RIGHT
  -->
  <section id="contact">
    <div class="particles-container"></div>
    <div class="container" style="position:relative;z-index:2;">
      <div class="section-label reveal-right">Let's Connect</div>
      <h2 class="section-title reveal-right delay-100">
        Get in <span class="gradient-text">Touch</span>
      </h2>

      <div class="contact-wrapper">
        <div class="contact-info">
          <a
            href="tel:+919487586961"
            class="contact-item reveal-left delay-100"
          >
            <div class="contact-icon">📞</div>
            <div>
              <div class="contact-label">Phone</div>
              <div class="contact-value">+91 9487586961</div>
            </div>
          </a>
          <div class="contact-item reveal-left delay-200">
            <div class="contact-icon">✉️</div>
            <div style="flex:1;">
              <div class="contact-label">Email</div>
              <div class="contact-value" id="emailValue">
                jestusjoestince@gmail.com
              </div>
            </div>
            <button
              class="copy-btn"
              id="copyEmail"
              title="Copy Email"
              aria-label="Copy email to clipboard"
            >
              <span class="copy-icon">📋</span>
              <span class="copy-feedback">Copied!</span>
            </button>
          </div>
          <a
            href="https://linkedin.com/in/jestus"
            target="_blank"
            rel="noopener"
            class="contact-item reveal-left delay-300"
          >
            <div class="contact-icon">💼</div>
            <div>
              <div class="contact-label">LinkedIn</div>
              <div class="contact-value">linkedin.com/in/jestus</div>
            </div>
          </a>
          <div
            class="contact-item reveal-left delay-400"
            style="cursor:default;"
          >
            <div class="contact-icon">📍</div>
            <div>
              <div class="contact-label">Location</div>
              <div class="contact-value">Tamil Nadu, India</div>
            </div>
          </div>
        </div>

        <div class="contact-cta reveal-right delay-200">
          <h3>Open to <span class="gradient-text">New Opportunities</span></h3>
          <p>
            I'm always excited about interesting projects and challenging roles.
            Whether it's a full-time position, contract work, or just a chat —
            I'd love to connect!
          </p>
          <button
            id="openContactModal"
            class="btn-primary"
            style="border:none;font-family:var(--font-sans);font-size:1rem;"
          >
            <span>Send Me an Email</span>
            <span>→</span>
          </button>
          <div
            style="margin-top:2rem;padding-top:2rem;border-top:1px solid var(--border-subtle);"
          >
            <p
              style="font-size:0.8rem;color:var(--text-muted);font-family:var(--font-mono);"
            >
              Currently at Centizen Inc. &nbsp;|&nbsp; Angular 18 · TypeScript ·
              RxJS · NgRx · Node.js
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer>
    <div class="footer-content">
      <div class="footer-text">
        <!-- &lt; Built with <span>Astro</span> &amp; ♥ /&gt; -->
      </div>
      <div class="footer-text">
        © 2026 <span>Jestus A</span>. All rights reserved.
      </div>
      <div class="footer-text">
        <span>Angular Dev</span> · Tamil Nadu, India
      </div>
    </div>

    <!-- ===== CONTACT MODAL ===== -->
    <div class="modal-overlay" id="contactModal">
      <div class="modal-content">
        <button
          class="modal-close"
          id="closeContactModal"
          aria-label="Close modal">×</button
        >

        <div class="modal-header">
          <h3 class="modal-title">
            Get in <span class="gradient-text">Touch</span>
          </h3>
          <p class="modal-subtitle">
            I'll get back to you securely at jestusjoestince@gmail.com
          </p>
        </div>

        <form id="contactForm" class="contact-form" novalidate>
          <input type="text" name="_honey" style="display:none" />
          <input type="hidden" name="_template" value="table" />
          <div class="form-group">
            <label for="frmName"
              >Full Name / Company <span class="req">*</span></label
            >
            <input
              type="text"
              id="frmName"
              name="name"
              required
              placeholder="e.g. Acme Corp Recruiter"
            />
            <span class="form-error">Please enter your name.</span>
          </div>

          <div class="form-group">
            <label for="frmEmail"
              >Email Address <span class="req">*</span></label
            >
            <input
              type="email"
              id="frmEmail"
              name="email"
              required
              placeholder="name@company.com"
            />
            <span class="form-error">Please enter a valid email.</span>
          </div>

          <div class="form-group">
            <label for="frmMessage">Message <span class="req">*</span></label>
            <textarea
              id="frmMessage"
              name="message"
              rows="4"
              required
              placeholder="Tell me about the role or project..."></textarea>
            <span class="form-error">Message cannot be empty.</span>
          </div>

          <button type="submit" class="btn-primary modal-submit" id="submitBtn">
            <span class="btn-text">Send Message</span>
            <span class="btn-loader"></span>
          </button>
        </form>
      </div>
    </div>

    <!-- ===== SNACKBAR ===== -->
    <div id="snackbar" class="snackbar">
      <div class="snackbar-icon"></div>
      <div class="snackbar-msg" id="snackbarMsg">
        Message sent successfully!
      </div>
    </div>
  </footer>

  <style>
    .hero-left {
      max-width: 600px;
    }
  </style>
</Layout>
